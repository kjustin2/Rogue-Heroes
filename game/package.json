{
  "name": "rogue-heroes-3d",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run typecheck && npm test && npm run build",
    "preview": "vite preview",
    "smoke:flow": "node scripts/smoke-flow.mjs",
    "smoke:economy": "node scripts/smoke-economy.mjs",
    "smoke:buttons": "node scripts/smoke-buttons.mjs",
    "screens": "node scripts/polish-screens.mjs",
    "improve:capture": "node improve/capture-flow.mjs",
    "improve:check": "node improve/check-goals.mjs",
    "improve:cycle": "node improve/run-cycle.mjs",
    "improve:gallery": "node improve/scenario-gallery.mjs",
    "perf": "node improve/perf-bench.mjs",
    "vision": "node improve/vision.mjs",
    "smoke:electron": "electron scripts/smoke-electron.cjs",
    "test:play": "npm run build && npm run smoke:electron",
    "test:full": "npm run verify && npm run smoke:buttons && npm run smoke:flow && npm run smoke:economy",
    "desktop": "electron .",
    "standalone": "npm run build && electron .",
    "dist:exe": "npm run build && electron-builder --win portable"
  },
  "author": "Rogue Heroes",
  "build": {
    "appId": "com.rogueheroes.tactical",
    "productName": "Rogue Heroes Tactics",
    "files": [
      "electron-main.cjs",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable"
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "postprocessing": "^6.39.2",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.1.0",
    "@types/three": "^0.170.0",
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8",
    "playwright-core": "^1.60.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
